rules_version = '2';

// このルールをFirebaseコンソール > Firestore Database > ルール タブに
// 貼り付けて「公開」してください。README.md の手順も参照。
//
// ⚠️ 下の YOUR_SCHOOL_DOMAIN を、実際の学校のGoogle Workspaceドメインに
//    書き換えてください(例: "xxx.ac.jp")。書き換えないと誰もアクセスできません
//    (安全側に倒れる=全員拒否になるので、動かない場合はまずここを疑ってください)。
//    firebase-config.js の requiredEmailDomain とも同じ値にしてください。
//
// 方針:
//   - このアプリは「学校ドメインのGoogleアカウントでログインしていること」を
//     すべての読み書きの条件にしています(サイト全体がログイン必須)。
//   - ログインさえしていれば、登録・予約・削除・連絡事項の編集など、
//     すべての操作を誰でも行えます(バンドごとの所有権チェックはしていません)。
//     これは部員内の信頼にもとづく運用を前提にした設計です。
//   - 「2週間で最大2件」「時間帯の重複禁止」「営業時間(祝日判定含む)」といった
//     複数ドキュメントをまたぐ複雑な業務ルールは、Firestoreルールの範囲では
//     効率的に検証できないため、引き続きクライアント側(app.js)でチェックしています。

service cloud.firestore {
  match /databases/{database}/documents {

    function isMember() {
      return request.auth != null
        && request.auth.token.email != null
        //&& request.auth.token.email.lower().matches('.*@okayama-u.ac.jp$');
        && request.auth.token.email.lower().matches('.*@(.*\\.)?okayama-u.ac.jp$');
    }

    match /bands/{bandId} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.keys().hasOnly(['name', 'nameLower', 'note', 'type', 'createdByEmail', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 30
        && request.resource.data.type in ['band', 'individual'];
      allow update: if false;
      allow delete: if isMember();
    }

    match /reservations/{resId} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.keys().hasOnly(['bandId', 'bandName', 'date', 'start', 'end', 'createdAt'])
        && request.resource.data.bandName is string
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10
        && request.resource.data.start is int
        && request.resource.data.end is int
        && request.resource.data.start >= 0
        && request.resource.data.end <= 1440
        && request.resource.data.end > request.resource.data.start
        && (request.resource.data.end - request.resource.data.start) <= 120
        && (request.resource.data.end - request.resource.data.start) % 30 == 0;
      allow update: if false;
      allow delete: if isMember();
    }

    match /notices/{noticeId} {
      allow read: if isMember();
      allow write: if isMember()
        && request.resource.data.keys().hasOnly(['text', 'updatedAt', 'updatedAtLabel'])
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 5000;
    }

    match /liveEvents/{id} {
      allow read: if isMember();
      allow create, update: if isMember()
        && request.resource.data.keys().hasOnly(['eventName', 'date', 'timeNote', 'venue', 'createdAt'])
        && request.resource.data.eventName is string && request.resource.data.eventName.size() <= 60
        && request.resource.data.venue is string && request.resource.data.venue.size() <= 60;
      allow delete: if isMember();
    }

    match /equipment/{id} {
      allow read: if isMember();
      allow create, update: if isMember()
        && request.resource.data.keys().hasOnly(['itemName', 'borrower', 'checkoutDate', 'returnDate', 'note', 'returned', 'createdAt'])
        && request.resource.data.itemName is string && request.resource.data.itemName.size() <= 40
        && request.resource.data.borrower is string && request.resource.data.borrower.size() <= 40
        && request.resource.data.returned is bool;
      allow delete: if isMember();
    }

    match /links/{id} {
      allow read: if isMember();
      allow create, update: if isMember()
        && request.resource.data.keys().hasOnly(['label', 'url', 'createdAt'])
        && request.resource.data.label is string && request.resource.data.label.size() <= 40
        && request.resource.data.url is string && request.resource.data.url.size() <= 300
        && request.resource.data.url.matches('^https?://.*');
      allow delete: if isMember();
    }
  }
}
